Options -Indexes
DirectoryIndex index.php

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<FilesMatch "(^\.|\.sql$|\.py$|\.bat$|\.db$|\.sqlite$|\.sqlite3$|\.log$|\.env$|requirements\.txt$)">
  Require all denied
</FilesMatch>

<FilesMatch "^(fix|gateway|legacy_bridge|serve_xampp|xampp_setup|xampp_start)\.">
  Require all denied
</FilesMatch>
